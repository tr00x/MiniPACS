# MiniPACS Portal — Environment Variables
# Copy to .env and fill in real values

# IMPORTANT: Generate with `python -c "import secrets; print(secrets.token_hex(32))"`
SECRET_KEY=generate-a-random-64-char-string
ORTHANC_URL=http://localhost:48923
ORTHANC_USERNAME=orthanc
# IMPORTANT: Change to a strong password, must match orthanc.json RegisteredUsers
ORTHANC_PASSWORD=set-a-strong-password
DATABASE_URL=sqlite+aiosqlite:///./minipacs.db
# Production: set to your clinic's HTTPS URL, e.g. ["https://pacs.clintonclinic.com"]
# NEVER use ["*"] — whitelist exact origins only
CORS_ORIGINS=["http://localhost:48920"]
AUTO_LOGOUT_MINUTES=15
DEFAULT_SHARE_EXPIRY_DAYS=30
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
