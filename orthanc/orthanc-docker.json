{
  "Name": "MiniPACS",

  "StorageDirectory": "/var/lib/orthanc/db",
  "IndexDirectory": "/var/lib/orthanc/db",
  "StorageCompression": false,
  "MaximumStorageSize": 0,
  "MaximumPatientCount": 0,

  "//": "With 7.6GB RAM available on the host we can give SQLite a 256MB in-process page cache, on top of OS page cache.",
  "SQLiteCacheSize": 268435456,

  "DicomServerEnabled": true,
  "DicomAet": "MINIPACS",
  "DicomPort": 4242,
  "DefaultEncoding": "Latin1",
  "DicomAssociationCloseDelay": 5,
  "DicomScuTimeout": 30,

  "HttpServerEnabled": true,
  "HttpPort": 8042,
  "RemoteAccessAllowed": true,
  "AuthenticationEnabled": true,
  "RegisteredUsers": {},

  "DicomModalitiesInDatabase": true,
  "DicomModalities": {},

  "OverwriteInstances": false,
  "StableAge": 60,
  "LimitFindResults": 1000,
  "LimitFindInstances": 0,
  "KeepAlive": true,
  "HttpTimeout": 60,
  "HttpThreadsCount": 10,
  "ConcurrentJobs": 2,
  "StorageAccessOnFind": "Never",

  "DicomWeb": {
    "Enable": true,
    "Root": "/dicom-web/",
    "EnableWado": true,
    "WadoRoot": "/wado",
    "Host": "localhost",
    "Ssl": false,
    "StudiesMetadata": "MainDicomTags",
    "SeriesMetadata": "Full"
  },

  "Transfers": {
    "PeerConnectivityTimeout": 15,
    "MaxHttpRetries": 3
  }
}
